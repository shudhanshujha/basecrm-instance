generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id             String          @id @default(uuid())
  name           String
  slug           String          @unique
  logoUrl        String?         @map("logo_url")
  taxMode        String          @default("NONE") @map("tax_mode")
  gstin          String?
  panNumber      String?         @map("pan_number")
  address        String?
  phone          String?
  email          String?
  bankName       String?         @map("bank_name")
  bankBranch     String?         @map("bank_branch")
  accountNumber  String?         @map("account_number")
  ifscCode       String?         @map("ifsc_code")
  upiId          String?         @map("upi_id")
  msmeRegNo      String?         @map("msme_reg_no")
  accentColor    String?         @default("#6366F1") @map("accent_color")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  activityLogs   ActivityLog[]
  deals          Deal[]
  clients        Client[]
  expenses       Expense[]
  files          File[]
  invoiceItems   InvoiceItem[]
  invoices       Invoice[]
  payments       Payment[]
  profiles       Profile[]
  quotations     Quotation[]
  assets         Asset[]
  invoiceTemplates InvoiceTemplate[]
  vendorPayments VendorPayment[]
  vendors        Vendor[]
  vendorContracts VendorContract[]

  @@map("organizations")
}

model Profile {
  id            String       @id @default(uuid()) @map("id")
  email         String       @unique
  password      String
  orgId         String       @map("org_id")
  fullName      String?      @map("full_name")
  role          String
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  uploadedFiles File[]       @relation("UploadedBy")
  organization  Organization @relation(fields: [orgId], references: [id])

  @@map("profiles")
}

model Client {
  id            String       @id @default(uuid())
  orgId         String       @map("org_id")
  name          String
  contactPerson String?      @map("contact_person")
  phone         String?
  email         String?
  address       String?
  city          String?
  state         String       @default("Generic")
  pincode       String?
  gstin         String?
  panNumber     String?      @map("pan_number")
  clientType    String       @default("REGULAR") @map("client_type")
  notes         String?
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  deals         Deal[]
  organization  Organization @relation(fields: [orgId], references: [id])
  files         File[]
  invoices      Invoice[]
  payments      Payment[]
  quotations    Quotation[]

  @@map("clients")
}

model Vendor {
  id              String           @id @default(uuid())
  orgId           String           @map("org_id")
  vendorName      String           @map("vendor_name")
  contactPerson   String?          @map("contact_person")
  phone           String?
  email           String?
  address         String?
  city            String?
  gstin           String?
  panNumber       String?          @map("pan_number")
  vendorType      String?          @map("vendor_type")
  bankName        String?          @map("bank_name")
  accountNumber   String?          @map("account_number")
  ifscCode        String?          @map("ifsc_code")
  status          String           @default("ACTIVE")
  notes           String?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  vendorPayments  VendorPayment[]
  vendorContracts VendorContract[]
  organization Organization @relation(fields: [orgId], references: [id])

  @@map("vendors")
}

model Asset {
  id           String        @id @default(uuid())
  orgId        String        @map("org_id")
  name         String        @map("name")
  category     String?       @map("category")
  description  String?       @map("description")
  status       String        @default("ACTIVE")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  activityLogs ActivityLog[]
  files        File[]
  invoiceItems InvoiceItem[]
  organization Organization  @relation(fields: [orgId], references: [id])

  @@map("assets")
}

model VendorContract {
  id           String       @id @default(uuid())
  orgId        String       @map("org_id")
  vendorId     String       @map("vendor_id")
  startDate    DateTime     @map("start_date")
  endDate      DateTime     @map("end_date")
  rate         Float        @map("rate")
  paymentTerms String?      @map("payment_terms")
  status       String       @default("ACTIVE")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  organization Organization @relation(fields: [orgId], references: [id])
  vendor       Vendor       @relation(fields: [vendorId], references: [id])

  @@map("vendor_contracts")
}

model Deal {
  id           String        @id @default(uuid())
  orgId        String        @map("org_id")
  title        String        @map("title")
  clientId     String        @map("client_id")
  startDate    DateTime      @map("start_date")
  endDate      DateTime      @map("end_date")
  value        Float?        @map("value")
  category     String?       @map("category")
  status       String        @default("LEAD")
  notes        String?
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")
  activityLogs ActivityLog[]
  client       Client        @relation(fields: [clientId], references: [id])
  organization Organization  @relation(fields: [orgId], references: [id])
  files        File[]
  invoices     Invoice[]

  @@map("deals")
}

model ActivityLog {
  id           String       @id @default(uuid())
  orgId        String       @map("org_id")
  dealId       String       @map("deal_id")
  assetId      String?      @map("asset_id")
  activityType String       @map("activity_type")
  description  String?
  timestamp    DateTime     @default(now()) @map("timestamp")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  deal         Deal         @relation(fields: [dealId], references: [id])
  organization Organization @relation(fields: [orgId], references: [id])
  asset        Asset?       @relation(fields: [assetId], references: [id])
  files        File[]

  @@map("activity_logs")
}

model Invoice {
  id                   String        @id @default(uuid())
  orgId                String        @map("org_id")
  invoiceNumber        String        @map("invoice_number")
  clientId             String        @map("client_id")
  dealId               String?       @map("deal_id")
  invoiceDate          DateTime      @default(now()) @map("invoice_date")
  dueDate              DateTime      @map("due_date")
  subtotal             Float
  discountAmount       Float         @default(0) @map("discount_amount")
  discountPercent      Float         @default(0) @map("discount_percent")
  taxableAmount        Float         @map("taxable_amount")
  cgstRate             Float         @default(9) @map("cgst_rate")
  sgstRate             Float         @default(9) @map("sgst_rate")
  igstRate             Float         @default(0) @map("igst_rate")
  cgstAmount           Float         @map("cgst_amount")
  sgstAmount           Float         @map("sgst_amount")
  igstAmount           Float         @map("igst_amount")
  totalAmount          Float         @map("total_amount")
  amountInWords        String?       @map("amount_in_words")
  status               String        @default("PENDING")
  notes                String?
  bankDetails          String?       @map("bank_details")
  paymentTerms         String?       @map("payment_terms")
  reverseCharge        String?       @default("N") @map("reverse_charge")
  upiId                String?       @map("upi_id")
  showUpiQr            Boolean?      @default(true) @map("show_upi_qr")
  showDigitalSignature Boolean?      @default(false) @map("show_digital_signature")
  signatureUrl         String?       @map("signature_url")
  templateId           String?       @map("template_id")
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")
  files                File[]
  invoiceItems         InvoiceItem[]
  deal                 Deal?         @relation(fields: [dealId], references: [id])
  client               Client        @relation(fields: [clientId], references: [id])
  organization         Organization  @relation(fields: [orgId], references: [id])
  payments             Payment[]
  template             InvoiceTemplate? @relation(fields: [templateId], references: [id])

  @@unique([orgId, invoiceNumber])
  @@map("invoices")
}

model InvoiceItem {
  id           String       @id @default(uuid())
  orgId        String       @map("org_id")
  invoiceId    String       @map("invoice_id")
  assetId      String?      @map("asset_id")
  assetName    String?      @map("asset_name")
  description  String?
  fromDate     DateTime?    @map("from_date")
  toDate       DateTime?    @map("to_date")
  quantity     Float        @default(1)
  rate         Float
  amount       Float
  hsn          String?
  discount     Float?       @default(0)
  cgstRate     Float?       @default(9) @map("cgst_rate")
  sgstRate     Float?       @default(9) @map("sgst_rate")
  igstRate     Float?       @default(0) @map("igst_rate")
  cgstAmount   Float?       @default(0) @map("cgst_amount")
  sgstAmount   Float?       @default(0) @map("sgst_amount")
  igstAmount   Float?       @default(0) @map("igst_amount")
  total        Float?       @default(0)
  createdAt    DateTime     @default(now()) @map("created_at")
  invoice      Invoice      @relation(fields: [invoiceId], references: [id])
  organization Organization @relation(fields: [orgId], references: [id])
  asset        Asset?       @relation(fields: [assetId], references: [id])

  @@map("invoice_items")
}

model Payment {
  id              String       @id @default(uuid())
  orgId           String       @map("org_id")
  invoiceId       String       @map("invoice_id")
  clientId        String       @map("client_id")
  paymentDate     DateTime     @map("payment_date")
  amount          Float
  paymentMode     String       @map("payment_mode")
  referenceNumber String?      @map("reference_number")
  bankName        String?      @map("bank_name")
  chequeNumber    String?      @map("cheque_number")
  chequeDate      DateTime?    @map("cheque_date")
  notes           String?      @map("notes")
  createdAt       DateTime     @default(now()) @map("created_at")
  client          Client       @relation(fields: [clientId], references: [id])
  invoice         Invoice      @relation(fields: [invoiceId], references: [id])
  organization    Organization @relation(fields: [orgId], references: [id])

  @@map("payments")
}

model VendorPayment {
  id              String       @id @default(uuid())
  orgId           String       @map("org_id")
  vendorId        String       @map("vendor_id")
  paymentDate     DateTime     @map("payment_date")
  amount          Float
  month           Int?
  year            Int?
  paymentMode     String       @map("payment_mode")
  referenceNumber String?      @map("reference_number")
  purpose         String?
  notes           String?
  createdAt       DateTime     @default(now()) @map("created_at")
  organization    Organization @relation(fields: [orgId], references: [id])
  vendor          Vendor       @relation(fields: [vendorId], references: [id])

  @@map("vendor_payments")
}

model Quotation {
  id              String       @id @default(uuid())
  orgId           String       @map("org_id")
  quotationNumber String       @map("quotation_number")
  clientId        String       @map("client_id")
  quotationDate   DateTime     @default(now()) @map("quotation_date")
  validUntil      DateTime     @map("valid_until")
  lineItems       String         @map("line_items")
  subtotal        Float
  gstAmount       Float        @map("gst_amount")
  totalAmount     Float        @map("total_amount")
  status          String       @default("DRAFT")
  notes           String?
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  client          Client       @relation(fields: [clientId], references: [id])
  organization    Organization @relation(fields: [orgId], references: [id])

  @@unique([orgId, quotationNumber])
  @@map("quotations")
}

model Expense {
  id              String       @id @default(uuid())
  orgId           String       @map("org_id")
  date            DateTime     @default(now())
  category        String
  amount          Float
  description     String?
  paymentMode     String?      @map("payment_mode")
  referenceNumber String?      @map("reference_number")
  gstin           String?
  taxableAmount   Float?       @map("taxable_amount")
  cgstAmount      Float?       @map("cgst_amount")
  sgstAmount      Float?       @map("sgst_amount")
  igstAmount      Float?       @map("igst_amount")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  organization    Organization @relation(fields: [orgId], references: [id])
  files           File[]

  @@map("expenses")
}

model InvoiceTemplate {
  id          String       @id @default(uuid())
  orgId       String       @map("org_id")
  name        String
  type        String       @default("CUSTOM")
  config      Json         @default("{}")
  isDefault   Boolean      @default(false) @map("is_default")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  organization Organization @relation(fields: [orgId], references: [id])
  invoices     Invoice[]

  @@map("invoice_templates")
}

model File {
  id            String       @id @default(uuid())
  orgId         String       @map("org_id")
  assetId       String?      @map("asset_id")
  dealId        String?      @map("deal_id")
  activityLogId String?      @map("activity_log_id")
  invoiceId     String?      @map("invoice_id")
  expenseId     String?      @map("expense_id")
  clientId      String?      @map("client_id")
  fileName      String       @map("file_name")
  fileKey       String       @map("file_key")
  fileSize      BigInt?      @map("file_size")
  mimeType      String?      @map("mime_type")
  uploadedBy    String?      @map("uploaded_by")
  createdAt     DateTime     @default(now()) @map("created_at")
  deal          Deal?        @relation(fields: [dealId], references: [id])
  activityLog   ActivityLog? @relation(fields: [activityLogId], references: [id])
  client        Client?      @relation(fields: [clientId], references: [id])
  expense       Expense?     @relation(fields: [expenseId], references: [id])
  invoice       Invoice?     @relation(fields: [invoiceId], references: [id])
  organization  Organization @relation(fields: [orgId], references: [id])
  asset         Asset?       @relation(fields: [assetId], references: [id])
  uploader      Profile?     @relation("UploadedBy", fields: [uploadedBy], references: [id])

  @@map("files")
}
